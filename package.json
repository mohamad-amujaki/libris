{
  "name": "libris",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r run build",
    "dev": "pnpm --parallel -r --filter @libris/api --filter @libris/web run dev",
    "dev:api": "pnpm --filter @libris/api dev",
    "dev:web": "pnpm --filter @libris/web dev",
    "lint": "biome check .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "db:generate": "pnpm --filter @libris/db exec prisma generate",
    "db:migrate": "pnpm --filter @libris/db exec prisma migrate dev",
    "db:push": "pnpm --filter @libris/db exec prisma db push",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "husky": "^9.1.7",
    "typescript": "^5.7.3"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  }
}
